{
    "server_host": "127.0.0.1",
    "server_port": 5000,

    "num_input_nodes": 30,
    "num_hidden_layer_nodes": [128, 256, 512, 256, 128],
    "num_output_nodes": 9,
    "relu_rate": 0.1,
    "dropout_rate": 0.1,

    "max_epochs": 100,
    "learn_rate": 1e-6,
    "batch_size": 500,
    "max_sessions": 500,
    "policy_sync_rate": 10,

    "session_template": "training-{:06d}-{:06d}",
    "good_move_score": 1,
    "invalid_move_score": -10,
    "default_move_score": -0.1,
    "discount_factor": 0.9,
    "p1_profile": "rl-agent",
    "p2_profile": "heuristic-agent",
    "exploration_rate": 1.0,
    "exploration_decay": 0.9
}