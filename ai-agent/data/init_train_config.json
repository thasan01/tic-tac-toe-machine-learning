{
    "server_host": "127.0.0.1",
    "server_port": 5000,

    "num_input_nodes": 30,
    "num_hidden_layer_nodes": [64, 128, 256, 512, 256, 128, 64],
    "num_output_nodes": 9,
    "relu_rate": 0.1,
    "dropout_rate": 0.1,

    "max_epochs": 500,
    "learn_rate_range": [1e-4, 1e-5],
    "learn_step_size": 100,
    "batch_size": 512,
    "max_sessions": 500,
    "policy_sync_rate": 5,
    "experience_replay": 0.75,
    "experience_retain_dist" : [0.8, 0.1, 0.1],
    "archive_rate": 5,


    "session_template": "training-{:06d}-{:06d}-{:01d}",
    "good_move_score": 1,
    "invalid_move_score": -1,
    "default_move_score": -0.01,
    "discount_factor": 0.95,
    "p1_profile": "heuristic-agent",
    "p2_profile": "rl-agent",
    "swap_players": false,
    "agent_player_id": 2,
    "exploration_rate": 1.0,
    "exploration_decay": 0.99,
    
    "eval_rate": 10
}
